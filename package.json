{
  "name": "@byeongsu-hong/tauri-agent-fleet",
  "version": "0.1.0",
  "description": "Parallel, isolated QA orchestration for Tauri applications",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byeongsu-hong/tauri-agent-fleet.git"
  },
  "homepage": "https://github.com/byeongsu-hong/tauri-agent-fleet#readme",
  "bugs": "https://github.com/byeongsu-hong/tauri-agent-fleet/issues",
  "publishConfig": { "access": "public" },
  "bin": {
    "tauri-agent-fleet": "dist/cli.js"
  },
  "files": ["dist", "README.md", "LICENSE-APACHE", "LICENSE-MIT"],
  "scripts": {
    "build": "bun build src/cli.ts --target=bun --external '@byeongsu-hong/tauri-agent-plugin/*' --outdir=dist && vite build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test && bun run build",
    "prepare": "bun run build",
    "prepack": "bun run check"
  },
  "dependencies": {
    "@byeongsu-hong/tauri-agent-plugin": "^0.0.2",
    "@novnc/novnc": "^1.6.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.19",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.1.2"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
